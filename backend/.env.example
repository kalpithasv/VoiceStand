DATABASE_URL=sqlite:///./dev.db
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Feed/moderation rules
POST_TTL_HOURS=5
LOCALITY_DECIMALS=2

# Images uploaded by users
UPLOAD_DIR=./uploads

# Comma-separated
CORS_ORIGINS=http://localhost:19006,http://localhost:3000

# Validation provider: agnes or anthropic
VALIDATION_PROVIDER=agnes

# Agnes AI (default provider for image/description validation)
AGNES_API_KEY=your-agnes-api-key
AGNES_MODEL=openai/gpt-4o-mini
# AGNES_BASE_URL should be your provider's API base URL.
# If Agnes gives a direct chat completions endpoint, use AGNES_CHAT_COMPLETIONS_URL instead.
AGNES_BASE_URL=https://zenmux.ai/api/v1
AGNES_CHAT_COMPLETIONS_URL=

# Optional Anthropic fallback
ANTHROPIC_API_KEY=
